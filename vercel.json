{
  "builds": [
    {
      "src": "huntly/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "huntly/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "huntly.settings.prod"
  }
}
