# Django core settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Allowed hosts (comma-separated list)
# Example: ALLOWED_HOSTS=yourdomain.com,.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (required in production)
# PostgreSQL URL format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Example providers: Neon (neon.tech), Supabase, Railway, ElephantSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Django settings module
# Use huntly.settings.prod for production (Vercel), huntly.settings.dev for local
DJANGO_SETTINGS_MODULE=huntly.settings.prod
